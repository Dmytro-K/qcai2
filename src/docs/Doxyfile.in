PROJECT_NAME = "qcai2"
OUTPUT_DIRECTORY = "@QCAI2_DOCS_DOXYGEN_OUTPUT_DIR@"
CREATE_SUBDIRS = NO
ALLOW_UNICODE_NAMES = YES
OUTPUT_LANGUAGE = English
BRIEF_MEMBER_DESC = YES
REPEAT_BRIEF = YES
ALWAYS_DETAILED_SEC = NO
INLINE_INHERITED_MEMB = YES
FULL_PATH_NAMES = YES
STRIP_FROM_PATH = "@CMAKE_CURRENT_SOURCE_DIR@"
QUIET = YES
WARN_IF_UNDOCUMENTED = NO
WARN_IF_DOC_ERROR = YES
INPUT = @QCAI2_DOXYGEN_INPUTS@
FILE_PATTERNS = *.h *.hh *.hpp *.hxx *.c *.cc *.cpp *.cxx *.m *.mm
RECURSIVE = YES
EXTRACT_ALL = YES
EXTRACT_PRIVATE = YES
EXTRACT_STATIC = YES
HIDE_UNDOC_MEMBERS = NO
HIDE_UNDOC_CLASSES = NO
GENERATE_HTML = NO
GENERATE_LATEX = NO
GENERATE_XML = YES
XML_OUTPUT = xml
XML_PROGRAMLISTING = YES
ENABLE_PREPROCESSING = YES
MACRO_EXPANSION = YES
EXPAND_ONLY_PREDEF = NO
PREDEFINED += Q_OBJECT=
PREDEFINED += Q_PROPERTY(x)=
PREDEFINED += Q_SIGNALS=public
PREDEFINED += Q_SLOTS=
PREDEFINED += Q_INVOKABLE=
PREDEFINED += signals=public
PREDEFINED += slots=
PREDEFINED += emit=
